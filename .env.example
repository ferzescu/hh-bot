HH_LOGIN=email@example.com
HH_PASSWORD=your_password
UPDATE_INTERVAL_HOURS=4

# Режим работы: update (поднятие резюме), apply (автоотклик), both (оба)
RUN_MODE=both

# URL поиска вакансий (скопировать из браузера hh.ru)
HH_SEARCH_URL=https://spb.hh.ru/search/vacancy?text=devops&salary=300000

# Claude API ключ для генерации сопроводительных писем
ANTHROPIC_API_KEY=sk-ant-...

# Максимум откликов за один запуск (по умолчанию 50)
MAX_APPLICATIONS=50

# Модель Claude для cover letter (по умолчанию claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Краткое описание вашего опыта (для генерации сопроводительных писем)
RESUME_SUMMARY=DevOps-инженер с 5-летним опытом. Kubernetes, Terraform, CI/CD, AWS.

# ID резюме для отклика (скопировать из URL: hh.ru/resume/XXXXXXX)
# Если не задано — используется первое доступное резюме
HH_RESUME_ID=
